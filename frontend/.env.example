# ----------------------------------------------------------------------------
# Prize Arena environment configuration
#
# The site runs WITHOUT any of these set: it falls back to seeded demo data
# and a mock checkout. Fill these in to enable the real Postgres + Stripe path.
# ----------------------------------------------------------------------------

# Postgres connection string. When set, the data layer uses Prisma instead of
# the in-memory seed store. Example for the docker-compose Postgres:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prizearena?schema=public"
DATABASE_URL=

# Stripe. When STRIPE_SECRET_KEY is set, checkout creates real PaymentIntents.
# Leave blank to use the built-in mock checkout (no card required).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public site URL (used for absolute links / Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
