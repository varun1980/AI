# Database
DATABASE_URL="postgresql://trading:trading_secret@localhost:5433/tradingdb"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Server
PORT=4001
FRONTEND_URL=http://localhost:3001

# Trading Mode
# true = paper trading (no real money), false = live trading
PAPER_TRADING=true

# Coinbase Advanced Trade API
# Get keys from: https://www.coinbase.com/settings/api
# Required for LIVE trading only. Paper trading works without keys.
COINBASE_API_KEY=
COINBASE_API_SECRET=
