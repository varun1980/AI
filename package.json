{
  "name": "prize-arena",
  "version": "1.0.0",
  "description": "Prize Arena - online prize competitions platform (win cars, cash & tech)",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "prisma:seed": "npm run prisma:seed --workspace=frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "competitions",
    "prize-draw",
    "raffle",
    "instant-win",
    "nextjs"
  ],
  "license": "UNLICENSED"
}
